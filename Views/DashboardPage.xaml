<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EvacuationDashboard.Views.DashboardPage"
             Title="Main Dashboard"
             BackgroundColor="#FFF0F5"
             NavigationPage.HasNavigationBar="False">

    <Grid ColumnDefinitions="7*, 3*">

        <ScrollView Grid.Column="0" Padding="20">
            <VerticalStackLayout Spacing="15">

                <Border Stroke="#FF69B4" StrokeThickness="1.5" BackgroundColor="#FFFFFF" Padding="15,10,15,10" StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="INTELLIGENT EVACUATION SYSTEM" FontFamily="GoogleSansBold" FontSize="16" TextColor="#FF1493"/>
                            <Label x:Name="UserRoleLabel" Text="Access Level: -" FontFamily="GoogleSansRegular" FontSize="12" TextColor="#808080"/>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1" Spacing="15" VerticalOptions="Center">
                            <Label x:Name="UserLabel" Text="Hello, User!" FontFamily="GoogleSansBold" FontSize="14" TextColor="#C71585" VerticalOptions="Center"/>
                            <Button Text="Sign Out" 
                                    FontFamily="GoogleSansBold" 
                                    FontSize="12" 
                                    BackgroundColor="#E74C3C" 
                                    TextColor="#FFFFFF" 
                                    CornerRadius="8" 
                                    HeightRequest="35"
                                    Clicked="OnSignOutClicked"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <Border x:Name="FuzzyBanner" StrokeThickness="0" BackgroundColor="#2ECC71" Padding="15" StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="🤖 FUZZY LOGIC SYSTEM: OVERALL BUILDING STATUS" FontFamily="GoogleSansBold" FontSize="11" TextColor="#FFFFFF" CharacterSpacing="1"/>
                        <Label x:Name="FuzzyStatusLabel" Text="🟢 SAFE (Risk Level: 12.4% - All systems normal)" FontFamily="GoogleSansBold" FontSize="18" TextColor="#FFFFFF"/>
                    </VerticalStackLayout>
                </Border>

                <Label Text="FLOOR MONITORING PANEL" FontFamily="GoogleSansBold" FontSize="12" TextColor="#C71585" Margin="5,5,0,-5" CharacterSpacing="1"/>
                <HorizontalStackLayout Spacing="8">
                    <Button x:Name="TabTab1" Text="Floor 1" FontFamily="GoogleSansBold" FontSize="13" BackgroundColor="#FF1493" TextColor="#FFFFFF" CornerRadius="8" WidthRequest="85" HeightRequest="38" Clicked="OnFloorTabClicked"/>
                    <Button x:Name="TabTab2" Text="Floor 2" FontFamily="GoogleSansBold" FontSize="13" BackgroundColor="#FFFFFF" TextColor="#FF1493" BorderColor="#FF69B4" BorderWidth="1" CornerRadius="8" WidthRequest="85" HeightRequest="38" Clicked="OnFloorTabClicked"/>
                    <Button x:Name="TabTab3" Text="Floor 3" FontFamily="GoogleSansBold" FontSize="13" BackgroundColor="#FFFFFF" TextColor="#FF1493" BorderColor="#FF69B4" BorderWidth="1" CornerRadius="8" WidthRequest="85" HeightRequest="38" Clicked="OnFloorTabClicked"/>
                    <Button x:Name="TabTab4" Text="Floor 4" FontFamily="GoogleSansBold" FontSize="13" BackgroundColor="#FFFFFF" TextColor="#FF1493" BorderColor="#FF69B4" BorderWidth="1" CornerRadius="8" WidthRequest="85" HeightRequest="38" Clicked="OnFloorTabClicked"/>
                    <Button x:Name="TabTab5" Text="Floor 5" FontFamily="GoogleSansBold" FontSize="13" BackgroundColor="#FFFFFF" TextColor="#FF1493" BorderColor="#FF69B4" BorderWidth="1" CornerRadius="8" WidthRequest="85" HeightRequest="38" Clicked="OnFloorTabClicked"/>
                </HorizontalStackLayout>

                <Border BackgroundColor="#FFFFFF" StrokeThickness="0" Padding="20" StrokeShape="RoundRectangle 15">
                    <VerticalStackLayout Spacing="15">

                        <Label x:Name="ActiveFloorTitle" Text="Live Telemetry: Floor 1" FontFamily="GoogleSansBold" FontSize="16" TextColor="#333333"/>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="15">
                            <Border Grid.Row="0" Grid.Column="0" Stroke="#F5F5F5" StrokeThickness="1" Padding="15" StrokeShape="RoundRectangle 10" BackgroundColor="#FAFAFA">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Smoke &amp; Carbon Monoxide Density" FontFamily="GoogleSansRegular" FontSize="11" TextColor="#808080"/>
                                    <Label x:Name="SmokeLabel" Text="0.01 dB/m | 12 ppm (🟢 SAFE)" FontFamily="GoogleSansBold" FontSize="14" TextColor="#2ECC71"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="1" Stroke="#F5F5F5" StrokeThickness="1" Padding="15" StrokeShape="RoundRectangle 10" BackgroundColor="#FAFAFA">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Ambient Temperature" FontFamily="GoogleSansRegular" FontSize="11" TextColor="#808080"/>
                                    <Label x:Name="TempLabel" Text="26.8°C (🟢 NORMAL)" FontFamily="GoogleSansBold" FontSize="14" TextColor="#2ECC71"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="0" Stroke="#F5F5F5" StrokeThickness="1" Padding="15" StrokeShape="RoundRectangle 10" BackgroundColor="#FAFAFA">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Sprinkler Water Pressure Valve" FontFamily="GoogleSansRegular" FontSize="11" TextColor="#808080"/>
                                    <Label x:Name="SprinklerLabel" Text="4.2 BAR (💧 READY)" FontFamily="GoogleSansBold" FontSize="14" TextColor="#3498DB"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Row="1" Grid.Column="1" Stroke="#F5F5F5" StrokeThickness="1" Padding="15" StrokeShape="RoundRectangle 10" BackgroundColor="#FAFAFA">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="UPS Backup Power Status" FontFamily="GoogleSansRegular" FontSize="11" TextColor="#808080"/>
                                    <Label x:Name="PowerLabel" Text="100% Charged (🔋 STANDBY)" FontFamily="GoogleSansBold" FontSize="14" TextColor="#2ECC71"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <VerticalStackLayout x:Name="MaintenanceExtraPanel" Spacing="12" Margin="0,10,0,0" IsVisible="False">
                            <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill"/>
                            <Label Text="IoT Network Grid &amp; HVAC Ventilation Telemetry" FontFamily="GoogleSansBold" FontSize="14" TextColor="#333333"/>

                            <Grid ColumnDefinitions="*,*">
                                <VerticalStackLayout Grid.Column="0" Spacing="3">
                                    <Label Text="IoT Gateway Mesh Network" FontFamily="GoogleSansRegular" FontSize="11" TextColor="#808080"/>
                                    <Label x:Name="IotStatusLabel" Text="📶 48/48 Nodes Online (14ms Latency)" FontFamily="GoogleSansBold" FontSize="13" TextColor="#2ECC71"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="Stairwell Pressurized Fan (Anti-Smoke)" FontFamily="GoogleSansRegular" FontSize="11" TextColor="#808080"/>
                                    <Label x:Name="HvacLabel" Text="❄️ SYSTEM STANDBY (OFF)" FontFamily="GoogleSansBold" FontSize="13" TextColor="#706573"/>
                                </VerticalStackLayout>
                            </Grid>

                            <Label Text="Recent System Fault Logs" FontFamily="GoogleSansBold" FontSize="12" TextColor="#696969" Margin="0,5,0,0"/>
                            <Border Stroke="#FFB6C1" StrokeThickness="1" Padding="10" BackgroundColor="#FFF5F7" StrokeShape="RoundRectangle 8">
                                <VerticalStackLayout Spacing="5">
                                    <Label x:Name="Log1Label" Text="• [16:30] Info: Routine Battery &amp; UPS Automation Test Completed." FontFamily="GoogleSansRegular" FontSize="11" TextColor="#333333"/>
                                    <Label x:Name="Log2Label" Text="• [14:15] Info: IoT Nodes Signal Calibration Drift Checked - Status Clear." FontFamily="GoogleSansRegular" FontSize="11" TextColor="#808080"/>
                                </VerticalStackLayout>
                            </Border>

                            <Button Text="Run Hardware Auto-Calibration" FontFamily="GoogleSansBold" BackgroundColor="#FF69B4" TextColor="#FFFFFF" HeightRequest="42" CornerRadius="10" Margin="0,5,0,0" Clicked="OnMaintenanceClicked"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="ManagerExtraPanel" Spacing="12" Margin="0,10,0,0" IsVisible="False">
                            <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill"/>
                            <Label Text="Management &amp; Evacuation Logistics" FontFamily="GoogleSansBold" FontSize="14" TextColor="#333333"/>

                            <Grid ColumnDefinitions="*,*">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="Occupants on this Floor" FontFamily="GoogleSansRegular" FontSize="12" TextColor="#808080"/>
                                    <Label x:Name="OccupantsLabel" Text="12 People" FontFamily="GoogleSansBold" FontSize="18" TextColor="#C71585"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="Electronic Gate Status" FontFamily="GoogleSansRegular" FontSize="12" TextColor="#808080"/>
                                    <Label x:Name="GateLabel" Text="🔒 LOCKED (Secured)" FontFamily="GoogleSansBold" FontSize="16" TextColor="#706573"/>
                                </VerticalStackLayout>
                            </Grid>

                            <Button Text="🚨 TRIGGER EMERGENCY EVACUATION ALARM 🚨" FontFamily="GoogleSansBold" BackgroundColor="#E74C3C" TextColor="#FFFFFF" HeightRequest="45" CornerRadius="10" Margin="0,5,0,0" Clicked="OnTriggerAlarmClicked"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Column="1" Stroke="#FFB6C1" StrokeThickness="1" BackgroundColor="#FFFFFF" Margin="0,20,20,20" StrokeShape="RoundRectangle 15">
            <Grid RowDefinitions="Auto, *, Auto" Padding="15">

                <VerticalStackLayout Grid.Row="0" Spacing="3" Margin="0,0,0,10">
                    <Label Text="🤖 EvacuAI Copilot" FontFamily="GoogleSansBold" FontSize="16" TextColor="#FF1493"/>
                    <Label Text="Emergency NLP Assistant" FontFamily="GoogleSansRegular" FontSize="11" TextColor="#808080"/>
                    <BoxView HeightRequest="1" Color="#FFD1DC" Margin="0,5,0,0"/>
                </VerticalStackLayout>

                <ScrollView Grid.Row="1" x:Name="ChatScrollView">
                    <VerticalStackLayout x:Name="ChatHistoryLayout" Spacing="10" Padding="0,5,0,5">
                        <Border BackgroundColor="#FFF5F7" StrokeThickness="0" Padding="10" HorizontalOptions="Start" WidthRequest="220" StrokeShape="RoundRectangle 10">
                            <Label Text="Hello! I am your EvacuAI Assistant. Ask me anything about safety instructions, sensors, or evacuation routes." FontFamily="GoogleSansRegular" FontSize="12" TextColor="#333333"/>
                        </Border>
                    </VerticalStackLayout>
                </ScrollView>

                <Grid Grid.Row="2" ColumnDefinitions="*, Auto" ColumnSpacing="8" Margin="0,10,0,0">
                    <Border Grid.Column="0" Stroke="#FFB6C1" StrokeThickness="1" StrokeShape="RoundRectangle 10" BackgroundColor="#FFF5F7" Padding="10,2,10,2" VerticalOptions="Center">
                        <Editor x:Name="ChatInput" 
                                Placeholder="Ask EvacuAI..." 
                                FontFamily="GoogleSansRegular" 
                                FontSize="13" 
                                PlaceholderColor="#808080" 
                                TextColor="#000000" 
                                AutoSize="TextChanges"
                                HeightRequest="35"
                                MaximumHeightRequest="120"
                                VerticalOptions="Center"
                                TextChanged="OnChatInputTextChanged"/>
                    </Border>
                    <Button Grid.Column="1" Text="Send" FontFamily="GoogleSansBold" FontSize="12" BackgroundColor="#FF1493" TextColor="#FFFFFF" CornerRadius="10" WidthRequest="65" HeightRequest="40" VerticalOptions="End" Clicked="OnSendChatClicked"/>
                </Grid>

            </Grid>
        </Border>

    </Grid>
</ContentPage>