<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EvacuationDashboard.Views.VerificationPage"
             Title="Face Verification"
             BackgroundColor="#FFF0F5"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center" Padding="30" Margin="0,20,0,20">

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="30,40,30,40"
                    WidthRequest="420"
                    HorizontalOptions="Center">

                <VerticalStackLayout Spacing="25">

                    <Label Text="Face Verification"
                           FontFamily="GoogleSansBold"
                           FontSize="24"
                           HorizontalOptions="Center"
                           TextColor="#C71585" />

                    <Label x:Name="WelcomeLabel"
                           Text="Hello, User!"
                           FontFamily="GoogleSansBold"
                           FontSize="16"
                           HorizontalOptions="Center"
                           TextColor="#FF1493"
                           Margin="0,-15,0,0"/>

                    <Label Text="Your face will be scanned to verify your identity when signing in. Please look directly at the camera."
                           FontFamily="GoogleSansRegular"
                           FontSize="13"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="#706573"
                           LineHeight="1.3"/>

                    <Border Stroke="#FF69B4" 
                            StrokeThickness="4" 
                            StrokeShape="RoundRectangle 100" 
                            HeightRequest="200" 
                            WidthRequest="200" 
                            HorizontalOptions="Center" 
                            Padding="0" 
                            Margin="0,10,0,10">
                        <Image x:Name="FacePreview"
                               Aspect="AspectFill"
                               BackgroundColor="#FCE4EC"/>
                    </Border>

                    <Button Text="Verify My Face"
                            FontFamily="GoogleSansBold"
                            BackgroundColor="#FF1493"
                            TextColor="White"
                            CornerRadius="25"
                            HeightRequest="50"
                            Clicked="OnTakePhotoClicked"/>

                    <Button Text="Cancel &amp; Sign Out"
                            FontFamily="GoogleSansRegular"
                            BackgroundColor="Transparent"
                            TextColor="#C71585"
                            Padding="0"
                            Margin="0,-10,0,0"
                            Clicked="OnCancelClicked"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>